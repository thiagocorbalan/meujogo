# Meu Jogo Production Environment Variables
# Copy to .env and fill in real values

# General
NODE_ENV=production
PORT=3000

# Database
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=meujogo_db
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/meujogo_db?schema=public

# JWT — Generate strong random secrets (e.g. openssl rand -hex 64)
JWT_SECRET=
JWT_REFRESH_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-domain.com/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_CALLBACK_URL=https://your-domain.com/auth/apple/callback
APPLE_PRIVATE_KEY=<your Apple Sign In private key (.p8 content)>

# Error Tracking (Sentry)
SENTRY_DSN=https://your-key@sentry.io/your-project

# Frontend
FRONTEND_URL=https://your-frontend-domain.com
APP_URL=https://your-frontend-domain.com
PUBLIC_API_BASE_URL=https://your-api-domain.com
API_BASE_URL=http://api:3000
