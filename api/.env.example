DATABASE_URL="postgresql://meujogo:meujogo@localhost:5432/meujogo_db?schema=public"
PORT=3000

# Frontend URL (used for invite link generation)
APP_URL=http://localhost:4000

# JWT
JWT_SECRET=meujogo-jwt-secret-dev-only-change-in-production
JWT_REFRESH_SECRET=meujogo-jwt-refresh-secret-dev-only-change-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Apple OAuth
APPLE_CLIENT_ID=your-apple-client-id
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_CALLBACK_URL=http://localhost:3000/auth/apple/callback
